# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# --- Ortam / API adresleri / olası client sırları ---
.env
.env.*

# --- Firebase / push (dosya yoksa zararı yok; oluşturunca commit etme) ---
google-services.json
GoogleService-Info.plist

# --- Android imzalama & mağaza (Play’e çıkınca mutlaka dışarıda tut) ---
*.keystore
key.properties
play-creds.json
play-store-credentials.json

# --- Google / hizmet hesabı anahtarları ---
*credentials*.json
*serviceAccount*.json

# npm’de özel registry token’ı varsa (sadece scope/registry metni commit edeceksen bu satırı sil)
.npmrc

# --- android/ klasörünü repoya alırsan (prebuild sonrası) ---
android/local.properties
android/key.properties
android/app/release/
android/**/*.keystore

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
